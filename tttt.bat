powershell.exe -ExecutionPolicy Bypass -WindowStyle Hidden -NoProfile -File "C:\ProgramData\WinRAR\WinRAR.ps1"
if %ERRORLEVEL% NEQ 0 echo ERROR: failed to rebuild 
endlocal
exit /b 0

